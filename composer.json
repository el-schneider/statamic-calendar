{
    "name": "el-schneider/statamic-calendar",
    "autoload": {
        "psr-4": {
            "ElSchneider\\StatamicCalendar\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ElSchneider\\StatamicCalendar\\Tests\\": "tests"
        }
    },
    "require": {
        "rlanvin/php-rrule": "^2.6",
        "statamic/cms": "^5.0 || ^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "laravel/pint": "^1.27"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "Statamic Calendar",
            "description": "Statamic Calendar addon"
        },
        "laravel": {
            "providers": [
                "ElSchneider\\StatamicCalendar\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
